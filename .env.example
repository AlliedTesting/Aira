# Copy this file to `.env` (do not commit `.env`) and fill in values.
# Precedence: environment variables override `.env`.

# -----------------------------------------------------------------------------
# Jira
# -----------------------------------------------------------------------------
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your-jira-api-token

# Back-compat (optional): older scripts used JIRA_USERNAME.
# JIRA_USERNAME=your.email@company.com

# -----------------------------------------------------------------------------
# Confluence / Wiki
# -----------------------------------------------------------------------------
CONFLUENCE_URL=https://yourcompany.atlassian.net/wiki
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token

# Back-compat (optional): older scripts used CONFLUENCE_USERNAME.
# CONFLUENCE_USERNAME=your.email@company.com

# -----------------------------------------------------------------------------
# TestRail
# -----------------------------------------------------------------------------
TESTRAIL_URL=https://company.testrail.io
TESTRAIL_USERNAME=your.username@company.com
TESTRAIL_API_KEY=your-testrail-api-key

# -----------------------------------------------------------------------------
# GitHub (optional)
# -----------------------------------------------------------------------------
GITHUB_BASE_URL=https://github.com
GITHUB_TOKEN=
# (optional) if you want repo-scoped operations
GITHUB_OWNER=
GITHUB_REPO=

# -----------------------------------------------------------------------------
# Bitbucket (optional)
# -----------------------------------------------------------------------------
BITBUCKET_BASE_URL=https://bitbucket.org
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
# (optional) if you want repo-scoped operations
BITBUCKET_WORKSPACE=
BITBUCKET_REPO=

